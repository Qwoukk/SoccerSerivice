{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "build-and-deploy": "vite build && gh-pages -d dist",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css,json,md}\""
  },
  "eslintIgnore": [
    "node_modules",
    "dist"
  ],
  "dependencies": {
    "axios": "^1.15.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.16.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.0.0",
    "vite": "^8.0.4",
    "vue-eslint-parser": "^10.4.0"
  }
}
